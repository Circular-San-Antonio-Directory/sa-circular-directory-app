# Airtable Configuration
# Get your API key from: https://airtable.com/account
AIRTABLE_API_KEY=your_api_key_here

# Find your Base ID in the Airtable API docs for your base
# It starts with "app" followed by alphanumeric characters
AIRTABLE_BASE_ID=your_base_id_here

# The name of the table you want to fetch data from
AIRTABLE_TABLE_NAME=your_table_name_here

# Railway PostgreSQL Database
# Get this from your Railway project's PostgreSQL service
# Format: postgresql://user:password@host:port/database
DATABASE_URL=postgresql://user:password@host:port/database

# Public site origin used for canonical URLs, Open Graph tags, sitemap entries,
# and robots.txt. Must be an absolute URL without a trailing slash.
# TODO: replace with real production domain before launch
NEXT_PUBLIC_SITE_URL=https://sacirculardirectory.com
