generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

/// This model or at least one of its fields has comments in the database, and requires an additional setup for migrations: Read more: https://pris.ly/d/database-comments
model business_actions {
  id                   Int       @id @default(autoincrement())
  airtable_id          String    @unique @db.VarChar(50)
  action               String    @db.VarChar(200)
  corresponding_action String?   @db.VarChar(100)
  display_order        Int?
  created_at           DateTime? @default(now()) @db.Timestamp(6)
  updated_at           DateTime? @default(now()) @db.Timestamp(6)
  icon_file            String?   @db.VarChar(50)
  colorway             String?   @db.VarChar(50)

  @@index([action], map: "idx_business_actions_action")
  @@index([airtable_id], map: "idx_business_actions_airtable_id")
}

